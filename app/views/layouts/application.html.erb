<!DOCTYPE html>
<html>
<head>
  <title>Why Bully?</title>
  <%= stylesheet_link_tag    "application", media: "all", "data-turbolinks-track" => true %>
  <%= csrf_meta_tags %>
</head>
<body>
<div class="navbar navbar-inverse navbar-fixed-top">
      <div class="navbar-inner">
        <div class="container">
          <button type="button" class="btn btn-navbar" data-toggle="collapse" data-target=".nav-collapse">
            <span class="icon-bar"></span>
            <span class="icon-bar"></span>
            <span class="icon-bar"></span>
          </button>
          <a class="brand" href="/">Why Bully?</a>
          <div class="nav-collapse collapse">
            <ul class="nav">
              <li><a href="/search">Schools</a></li>
              <li><a href="/map">Map</a></li>
              <li><a href="/report">Report</a></li>
            </ul>
          </div><!--/.nav-collapse -->
          <a href="/report" class="btn btn-danger pull-right visible-desktop">
            <i class="icon-eye-open icon-white"></i> Report Bullying Now!
          </a>
        </div>
      </div>
    </div>
    
    <div class="container">
        
      <%= yield %>

    </div> <!-- /container -->


<%= javascript_include_tag "application", "data-turbolinks-track" => true %>
<script type="text/javascript" src="https://maps.googleapis.com/maps/api/js?sensor=true&libraries=visualization"></script>
</body>
</html>
